NODE_ENV=development
PORT=3000

# Set true on Render/reverse-proxy hosts (Render auto-detects via RENDER env too)
TRUST_PROXY=true

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/karyor?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Google Sign-In — OAuth 2.0 Web client (Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Analytics 4 — admin dashboard stats (Analytics Data API)
# Property ID: GA Admin → Property settings → Property ID (numeric, e.g. 123456789)
GA4_PROPERTY_ID=
# Service account JSON (single line). Create in Google Cloud → IAM → Service Accounts
# Enable "Google Analytics Data API", then add service account email as Viewer in GA4 property
GA4_SERVICE_ACCOUNT_JSON=

CLIENT_URL=http://localhost:5173,http://localhost:5174

ADMIN_EMAIL=admin@karyor.com
ADMIN_PASSWORD=change_this_admin_password
ADMIN_NAME=Karyor Admin

# Public API URL — Shiprocket webhook + admin panel (NEVER use localhost here)
# Local dev: still use your Render/live API URL so webhooks show correctly in admin
API_PUBLIC_URL=https://karyor-api.onrender.com

# Razorpay (https://dashboard.razorpay.com/app/keys) — fallback if not set in admin panel
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Encrypts payment/shipping credentials stored in database (REQUIRED in production — keep stable across deploys)
SETTINGS_ENCRYPTION_KEY=your_settings_encryption_key_change_in_production

# Shiprocket (https://app.shiprocket.in) — API user email/password
# Create API user: Settings → API → Create API User
SHIPROCKET_EMAIL=api-user@yourcompany.com
SHIPROCKET_PASSWORD=your_shiprocket_api_password

# Warehouse / pickup (must match pickup location name in Shiprocket panel)
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_PINCODE=125001
SHIPROCKET_COMPANY_NAME=Karyor Farms
SHIPROCKET_COMPANY_PHONE=8708621377
SHIPROCKET_COMPANY_EMAIL=karyorfarms@gmail.com
SHIPROCKET_COMPANY_ADDRESS=Hisar, Haryana
SHIPROCKET_COMPANY_CITY=Hisar
SHIPROCKET_COMPANY_STATE=Haryana
SHIPROCKET_COMPANY_PINCODE=125001
SHIPROCKET_DEFAULT_WEIGHT=0.5
SHIPROCKET_DEFAULT_LENGTH=20
SHIPROCKET_DEFAULT_BREADTH=15
SHIPROCKET_DEFAULT_HEIGHT=10
SHIPROCKET_AUTO_ASSIGN_AWB=true

# Webhook security token (set same token in Shiprocket webhook settings)
# Webhook URL: https://your-api-domain.com/api/webhooks/shiprocket
SHIPROCKET_WEBHOOK_SECRET=change_this_shiprocket_webhook_secret

# Cloudinary Integration for Persistent Image Uploads
CLOUDINARY_CLOUD_NAME=dhjnveoxf
CLOUDINARY_API_KEY=653826513325658
CLOUDINARY_API_SECRET=6Ai3gK00CHgs7nSGjk9suixfp6c