{
  "name": "karyor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "npm run dev --prefix server",
    "dev:admin": "npm run dev --prefix admin",
    "kill-ports": "node scripts/kill-dev-ports.cjs",
    "dev:local": "node scripts/kill-dev-ports.cjs && concurrently -k -n server,store,admin -c blue,green,yellow \"npm run dev:server\" \"npm run dev\" \"npm run dev:admin\"",
    "dev:all": "npm run dev:local",
    "build": "vite build",
    "build:admin": "npm run build --prefix admin",
    "build:all": "npm run build && npm run build:admin",
    "verify:deploy": "node scripts/verify-deploy.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "npm start --prefix server"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
