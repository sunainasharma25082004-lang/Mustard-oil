# Copy to .env.local for local dev (recommended) or .env
# Leave VITE_API_URL empty to use Vite proxy → localhost:3000
VITE_API_URL=
VITE_STORE_URL=http://localhost:5173
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Google Sign-In (OAuth 2.0 Web client — same Client ID as server GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com